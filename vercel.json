{
  "version": 2,
  "rewrites": [
    {
      "source": "/(api|auth|voice|upload|chat|docs|openapi\\.json)(/.*)?",
      "destination": "/api/index.py"
    },
    {
      "source": "/buscofacil/(.*)",
      "destination": "/frontend/buscofacil/$1"
    },
    {
      "source": "/xkape/(.*)",
      "destination": "/frontend/xkape/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
